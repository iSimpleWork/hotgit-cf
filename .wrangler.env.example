# 本地部署环境变量模板 - 复制为 .wrangler.env 并填入真实值
# 使用方式：cp .wrangler.env.example .wrangler.env && vi .wrangler.env
#           source .wrangler.env && npx wrangler deploy

# Cloudflare 账号 ID（在 dash.cloudflare.com 右侧边栏查看）
export CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# Cloudflare API Token（需要 Workers Edit + D1 Edit 权限）
export CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# D1 数据库 ID（运行 wrangler d1 create hotgit-db 后获取）
export HOTGIT_D1_DATABASE_ID=your_d1_database_id

# GitHub Personal Access Token（只需 public_repo 权限，用于提升 API 限额）
# 通过 wrangler secret put GITHUB_TOKEN 注入到 Worker，不写入代码
export GITHUB_TOKEN=your_github_pat_token
