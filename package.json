{
  "name": "hotgit-cf",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "GitHub trending repos tracker on Cloudflare Workers + D1",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply hotgit-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply hotgit-db --remote",
    "db:create": "wrangler d1 create hotgit-db",
    "test": "node test/run.js"
  },
  "devDependencies": {
    "wrangler": "^4.78.0"
  }
}
